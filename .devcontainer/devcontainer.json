{
  "name": "Malgosha Agent Dev",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/azure-cli:1": {},
    "ghcr.io/devcontainers-contrib/features/azd-cli:1": {}
  },
  "forwardPorts": [3000, 3001, 3002, 3003, 3004, 3010, 3011, 8081],
  "portsAttributes": {
    "3000": {
      "label": "App",
      "onAutoForward": "notify"
    },
    "3001": {
      "label": "mcp-memory",
      "onAutoForward": "silent"
    },
    "3002": {
      "label": "mcp-graph",
      "onAutoForward": "silent"
    },
    "3003": {
      "label": "mcp-http",
      "onAutoForward": "silent"
    },
    "3004": {
      "label": "mcp-files",
      "onAutoForward": "silent"
    },
    "3010": {
      "label": "telegram-adapter",
      "onAutoForward": "silent"
    },
    "3011": {
      "label": "teams-adapter",
      "onAutoForward": "silent"
    },
    "8081": {
      "label": "Cosmos Emulator",
      "onAutoForward": "silent"
    }
  },
  "remoteUser": "node",
  "postCreateCommand": "npm install && npm run install:all",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.vscode-typescript-next",
        "ms-vscode.vscode-node-debug2",
        "ms-azure-tools.vscode-bicep",
        "ms-azure-tools.vscode-azureappservice",
        "eamodio.gitlens",
        "redhat.vscode-yaml",
        "bierner.markdown-preview-github-styles",
        "ms-python.python"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[typescript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[json]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "typescript.tsdk": "node_modules/typescript/lib",
        "typescript.enablePromptUseWorkspaceTsdk": true
      }
    }
  }
}
