{
  "content_safety": {
    "level": "medium",
    "block_categories": [
      "HateSpeech",
      "Violence",
      "SelfHarm",
      "Sexual"
    ],
    "threshold": 0.7
  },
  "prompt_injection": {
    "enabled": true,
    "rules": [
      {
        "pattern": "ignore.*prompt",
        "action": "block",
        "message": "Instruction modification detected"
      }
    ]
  },
  "rate_limiting": {
    "enabled": true,
    "requests_per_minute": 60,
    "requests_per_hour": 1000
  }
}
