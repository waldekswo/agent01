{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Fact (Knowledge)",
  "type": "object",
  "required": ["subject", "predicate", "object", "userId"],
  "properties": {
    "id": { "type": "string" },
    "subject": {
      "type": "string",
      "examples": ["user:john@company.com", "team:sales", "org:company"]
    },
    "predicate": {
      "type": "string",
      "examples": ["prefers_language", "department", "reports_to", "email"]
    },
    "object": { "description": "Value of the fact" },
    "evidenceIds": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.9 },
    "ttl": { "type": "integer", "description": "Seconds until expiry" },
    "userId": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
